<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="true"
    android:focusable="true">

    <!-- Fondo por defecto cuando no hay imagen personalizada -->
    <View
        android:id="@+id/overlay_background_default"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E61F1F2E" />

    <!-- Imagen de fondo: cubre toda la pantalla (ajustar tamaño/posición en Configuración) -->
    <ImageView
        android:id="@+id/overlay_custom_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="Imagen personalizada pantalla de bloqueo"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <!-- Capa semitransparente para que el texto sea legible; la imagen se ve de fondo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B31F1F2E"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:id="@+id/overlay_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚫 App bloqueada"
            android:textColor="#FFB087FC"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/overlay_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Aplicación"
            android:textColor="#FFFFFFFF"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/overlay_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="Esta aplicación está bloqueada por Stay Focused.\nTómate un descanso."
            android:textColor="#FFB3B3B3"
            android:textSize="14sp" />

        <Button
            android:id="@+id/overlay_btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:backgroundTint="#FF03D9D6"
            android:text="Volver al inicio"
            android:textColor="#FF000000" />
    </LinearLayout>
</FrameLayout>
